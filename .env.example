# Copy to .env for local dev, OR set these as environment variables on your host.
# Do NOT commit real secrets.

# Groq API key for AI extraction (required for document analysis)
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default model
# GROQ_MODEL=llama-3.3-70b-versatile

# Login passwords (change these to strong values before hosting)
PARTNER_PASSWORD=change_me_partner
ADMIN_PASSWORD=change_me_admin

# Port (most hosts inject their own PORT automatically)
PORT=3000
